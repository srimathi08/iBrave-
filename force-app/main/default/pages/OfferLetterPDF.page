<apex:page controller="OfferLetterController" 
    renderAs="PDF" 
    applyHtmlTag="false" 
    showHeader="false" 
    sidebar="false" 
    docType="html-5.0">

    <html>
    <head>
        <style type="text/css">

	            @page {
                size: A4;
                margin: 1.25in 1in 0.8in 1in;
                padding: 0;
				@top-left {
                    content: element(header);
                }
            }
            body { 
                font-family: Arial, sans-serif; 
                font-size: 10pt;
                line-height: 1.5;
                color: #000;
            }
		    .pdf-header {
                text-align: left;
                margin-bottom: 20px; /* Add space below the logo/header */
            height: 95px; /* Define the height of the logo/header area */
                /* THIS IS THE KEY: Defines this element as repeatable on all pages */
                position: running(header);
			}
            .header-info { 
                margin-bottom: 15px; 
            }
            .section-heading {
                font-size: 11pt;
                font-weight: bold;
                margin-top: 25px;
                margin-bottom: 10px;
            }
 /* Styling for the Candidate's Required Documents List */
            .required-docs {
                margin-left: 15px; /* Adjust to better align with main content */
            }
            .signature-block { 
                margin-top: 40px; 
            }
 .signature-block-candidate {
                margin-top: 50px;
                display: block; /* Ensures it takes full width for alignment */
            }
            
	 		.signature-image {
                width: 150px;
                height: auto;
                margin-top: 10px;
                margin-bottom: 5px;
            }
            /* Table spacing for Annexure 1 and 2*/
            table {
                width: 100%;
                border-collapse: collapse;
            }
            th, td {
                padding: 8px 10px;
                text-align: left;
                vertical-align: top;
            }
            ol {
                margin-left: 20px;
                padding-left: 0;
            }
            ol li {
                margin-bottom: 8px;
            }
            .page-break {
                page-break-after: always;
            }
.footer-block {
    margin-top: 50px;
    border-top: 2px solid #000;
    padding-top: 10px;
    font-size: 10pt;
    line-height: 1.4;
}

        </style>
    </head>

