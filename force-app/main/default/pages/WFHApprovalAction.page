<apex:page controller="WFHApprovalAction" showHeader="false" standardStylesheets="false" docType="html-5.0" cache="false">
    <html lang="en">
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
        <title>WFH Approval Action - {!actionText} Request</title>
        
        <!-- Favicon -->
        <link rel="icon" type="image/x-icon" href="data:image/x-icon;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNkYPhfDwAChwGA60e6kgAAAABJRU5ErkJggg=="/>
        
        <style>
            /* Reset and Base Styles */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            
            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, -apple-system, BlinkMacSystemFont, sans-serif;
                line-height: 1.6;
                color: #333;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                animation: backgroundShift 10s ease-in-out infinite alternate;
            }
            
            @keyframes backgroundShift {
                0% { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
                100% { background: linear-gradient(135deg, #764ba2 0%, #667eea 100%); }
            }
            
            .main-container {
                background: white;
                border-radius: 16px;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
                max-width: 700px;
                width: 100%;
                overflow: hidden;
                position: relative;
                animation: slideInUp 0.6s ease-out;
            }
            
            @keyframes slideInUp {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            
            /* Header Styles */
            .header {
                background: linear-gradient(135deg, #1589ee 0%, #0070d2 100%);
                color: white;
                padding: 40px 30px;
                text-align: center;
                position: relative;
            }
            
            .header.approve {
                background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            }
            
            .header.reject {
                background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            }
            
            .header::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="white" opacity="0.1"/><circle cx="75" cy="75" r="1" fill="white" opacity="0.1"/><circle cx="50" cy="10" r="0.5" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
                opacity: 0.1;
            }
            
            .header h1 {
                font-size: 28px;
                font-weight: 700;
                margin-bottom: 10px;
                position: relative;
                z-index: 1;
            }
            
            .header .subtitle {
                font-size: 16px;
                opacity: 0.9;
                position: relative;
                z-index: 1;
            }
            
            .header .action-badge {
                display: inline-block;
                background: rgba(255, 255, 255, 0.2);
                border: 2px solid rgba(255, 255, 255, 0.3);
                border-radius: 50px;
                padding: 8px 20px;
                margin-top: 15px;
                font-size: 14px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 1px;
                position: relative;
                z-index: 1;
            }
            
            /* Content Styles */
            .content {
                padding: 40px 30px;
            }
            
            .employee-info-card {
                background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
                border-radius: 12px;
                padding: 25px;
                margin-bottom: 30px;
                border-left: 5px solid #1589ee;
                position: relative;
            }
            
            .employee-info-card::before {
                content: '👤';
                position: absolute;
                top: -10px;
                left: 20px;
                background: white;
                padding: 5px 10px;
                border-radius: 20px;
                font-size: 16px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            }
            
            .employee-info-card h3 {
                color: #333;
                margin-bottom: 20px;
                font-size: 18px;
                font-weight: 600;
            }
            
            .info-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 15px;
            }
            
            .info-item {
                display: flex;
                flex-direction: column;
            }
            
            .info-label {
                font-size: 12px;
                font-weight: 600;
                color: #666;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 5px;
            }
            
            .info-value {
                font-size: 15px;
                font-weight: 500;
                color: #333;
                background: white;
                padding: 8px 12px;
                border-radius: 6px;
                border: 1px solid #e0e0e0;
            }
            
            .reason-section {
                background: #fff5f5;
                border: 1px solid #fecaca;
                border-radius: 10px;
                padding: 20px;
                margin: 25px 0;
                position: relative;
            }
            
            .reason-section::before {
                content: '💬';
                position: absolute;
                top: -10px;
                left: 20px;
                background: white;
                padding: 5px 10px;
                border-radius: 20px;
                font-size: 16px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            }
            
            .reason-section h4 {
                color: #b91c1c;
                margin-bottom: 15px;
                font-size: 16px;
                font-weight: 600;
            }
            
            .reason-text {
                background: white;
                border: 1px solid #e5e7eb;
                border-radius: 8px;
                padding: 15px;
                font-size: 14px;
                line-height: 1.6;
                color: #374151;
                max-height: 120px;
                overflow-y: auto;
            }
            
            /* Form Styles */
            .form-section {
                margin: 30px 0;
            }
            
            .form-group {
                margin-bottom: 25px;
            }
            
            .form-label {
                display: block;
                margin-bottom: 8px;
                font-weight: 600;
                color: #374151;
                font-size: 14px;
            }
            
            .form-control {
                width: 100%;
                padding: 12px 16px;
                border: 2px solid #e5e7eb;
                border-radius: 8px;
                font-size: 14px;
                font-family: inherit;
                transition: all 0.3s ease;
                resize: vertical;
                min-height: 100px;
            }
            
            .form-control:focus {
                outline: none;
                border-color: #1589ee;
                box-shadow: 0 0 0 3px rgba(21, 137, 238, 0.1);
                transform: translateY(-1px);
            }
            
            .form-control::placeholder {
                color: #9ca3af;
                font-style: italic;
            }
            
            /* Button Styles */
            .button-section {
                display: flex;
                justify-content: center;
                gap: 15px;
                margin-top: 35px;
                flex-wrap: wrap;
            }
            
            .btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 14px 30px;
                border: none;
                border-radius: 8px;
                font-size: 16px;
                font-weight: 600;
                text-decoration: none;
                cursor: pointer;
                transition: all 0.3s ease;
                min-width: 140px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                position: relative;
                overflow: hidden;
            }
            
            .btn::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                width: 0;
                height: 0;
                background: rgba(255, 255, 255, 0.2);
                border-radius: 50%;
                transform: translate(-50%, -50%);
                transition: all 0.5s ease;
            }
            
            .btn:hover::before {
                width: 300px;
                height: 300px;
            }
            
            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            }
            
            .btn:active {
                transform: translateY(0);
            }
            
            .btn.approve {
                background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
                color: white;
                box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);
            }
            
            .btn.reject {
                background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
                color: white;
                box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
            }
            
            .btn.secondary {
                background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
                color: white;
                box-shadow: 0 4px 15px rgba(108, 117, 125, 0.3);
            }
            
            /* Result Styles */
            .result-section {
                text-align: center;
                padding: 50px 30px;
            }
            
            .result-icon {
                font-size: 64px;
                margin-bottom: 25px;
                animation: bounceIn 0.8s ease-out;
            }
            
            @keyframes bounceIn {
                0% {
                    opacity: 0;
                    transform: scale(0.3);
                }
                50% {
                    opacity: 1;
                    transform: scale(1.05);
                }
                70% {
                    transform: scale(0.9);
                }
                100% {
                    opacity: 1;
                    transform: scale(1);
                }
            }
            
            .result-title {
                font-size: 24px;
                font-weight: 700;
                margin-bottom: 15px;
            }
            
            .result-message {
                font-size: 16px;
                line-height: 1.6;
                margin-bottom: 25px;
            }
            
            .result.success .result-icon {
                color: #28a745;
            }
            
            .result.success .result-title {
                color: #28a745;
            }
            
            .result.error .result-icon {
                color: #dc3545;
            }
            
            .result.error .result-title {
                color: #dc3545;
            }
            
            .result.info .result-icon {
                color: #17a2b8;
            }
            
            .result.info .result-title {
                color: #17a2b8;
            }
            
            /* Additional Info Styles */
            .info-box {
                background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
                border: 1px solid #90caf9;
                border-radius: 10px;
                padding: 20px;
                margin: 25px 0;
                position: relative;
            }
            
            .info-box::before {
                content: 'ℹ️';
                position: absolute;
                top: -10px;
                left: 20px;
                background: white;
                padding: 5px 10px;
                border-radius: 20px;
                font-size: 16px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            }
            
            .info-box h4 {
                color: #1565c0;
                margin-bottom: 10px;
                font-size: 16px;
                font-weight: 600;
            }
            
            .info-list {
                list-style: none;
                padding: 0;
            }
            
            .info-list li {
                padding: 5px 0;
                color: #1976d2;
                font-size: 14px;
                position: relative;
                padding-left: 20px;
            }
            
            .info-list li::before {
                content: '•';
                color: #1976d2;
                position: absolute;
                left: 0;
                font-weight: bold;
            }
            
            /* Footer Styles */
            .footer {
                background: #f8f9fa;
                border-top: 1px solid #e9ecef;
                padding: 20px 30px;
                text-align: center;
                font-size: 12px;
                color: #6c757d;
            }
            
            .footer-links {
                margin-top: 10px;
            }
            
            .footer-links a {
                color: #1589ee;
                text-decoration: none;
                margin: 0 10px;
            }
            
            .footer-links a:hover {
                text-decoration: underline;
            }
            
            /* Responsive Design */
            @media (max-width: 768px) {
                body {
                    padding: 10px;
                }
                
                .main-container {
                    border-radius: 12px;
                }
                
                .header {
                    padding: 30px 20px;
                }
                
                .header h1 {
                    font-size: 24px;
                }
                
                .content {
                    padding: 30px 20px;
                }
                
                .info-grid {
                    grid-template-columns: 1fr;
                    gap: 10px;
                }
                
                .button-section {
                    flex-direction: column;
                    align-items: center;
                }
                
                .btn {
                    width: 100%;
                    max-width: 280px;
                }
                
                .result-section {
                    padding: 40px 20px;
                }
                
                .result-icon {
                    font-size: 48px;
                }
                
                .result-title {
                    font-size: 20px;
                }
            }
            
            @media (max-width: 480px) {
                .header {
                    padding: 25px 15px;
                }
                
                .content {
                    padding: 25px 15px;
                }
                
                .employee-info-card,
                .reason-section,
                .info-box {
                    padding: 15px;
                }
                
                .btn {
                    padding: 12px 20px;
                    font-size: 14px;
                }
            }
            
            /* Loading Animation */
            .loading {
                display: inline-block;
                width: 20px;
                height: 20px;
                border: 3px solid rgba(255, 255, 255, 0.3);
                border-radius: 50%;
                border-top-color: white;
                animation: spin 1s ease-in-out infinite;
                margin-right: 10px;
            }
            
            @keyframes spin {
                to { transform: rotate(360deg); }
            }
            
            /* Accessibility */
            .sr-only {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }
            
            /* Focus Styles */
            .btn:focus,
            .form-control:focus {
                outline: 2px solid #1589ee;
                outline-offset: 2px;
            }
        </style>
    </head>
    
    <body>
        <div class="main-container">
            <apex:form >
                <!-- Show confirmation form -->
                <apex:outputPanel rendered="{!showForm && !isProcessed}">
                    <div class="header {!LOWER(action)}">
                        <h1>
                            <apex:outputText value="✓ Approve WFH Request" rendered="{!LOWER(action) == 'approve'}"/>
                            <apex:outputText value="✗ Reject WFH Request" rendered="{!LOWER(action) == 'reject'}"/>
                        </h1>
                        <p class="subtitle">Manager Approval Required</p>
                        <div class="action-badge">
                            <apex:outputText value="Approval Action" rendered="{!LOWER(action) == 'approve'}"/>
                            <apex:outputText value="Rejection Action" rendered="{!LOWER(action) == 'reject'}"/>
                        </div>
                    </div>
                    
                    <div class="content">
                        <div class="employee-info-card">
                            <h3>Employee Information</h3>
                            <div class="info-grid">
                                <div class="info-item">
                                    <span class="info-label">Employee Name</span>
                                    <span class="info-value">{!attendance.Employee_Name__r.Name}</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Request Date</span>
                                    <span class="info-value">
                                        <apex:outputText value="{0, date, MMMM d, yyyy}">
                                            <apex:param value="{!attendance.Date__c}"/>
                                        </apex:outputText>
                                    </span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Current Status</span>
                                    <span class="info-value">{!attendance.WFH_Approval_Status__c}</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Work Location</span>
                                    <span class="info-value">{!attendance.Work_Location__c}</span>
                                </div>
                            </div>
                        </div>
                        
                        <apex:outputPanel rendered="{!NOT(ISBLANK(attendance.WFH_Reason__c))}">
                            <div class="reason-section">
                                <h4>Employee's Reason for WFH Request:</h4>
                                <div class="reason-text">
                                    <apex:outputText value="{!attendance.WFH_Reason__c}" escape="false"/>
                                </div>
                            </div>
                        </apex:outputPanel>
                        
                        <div class="form-section">
                            <div class="form-group">
                                <label class="form-label" for="comments">Manager Comments (Optional):</label>
                                <apex:inputTextarea value="{!comments}" 
                                                  styleClass="form-control" 
                                                  rows="4" 
                                                  id="comments" 
                                                  html-placeholder="Add any comments about your decision... (Optional)"/>
                            </div>
                        </div>
                        
                        <div class="info-box">
                            <h4>Important Notes:</h4>
                            <ul class="info-list">
                                <li>Your decision will be immediately reflected in the employee's attendance record</li>
                                <li>The employee will receive an automatic email notification of your decision</li>
                                <li>If approved, the day will be marked as "Work from Home - Approved"</li>
                                <li>If rejected, the day will be considered as LOP (Loss of Pay)</li>
                                <li>This action cannot be easily undone - please review carefully</li>
                            </ul>
                        </div>
                        
                        <div class="button-section">
                            <apex:commandButton value="{!'Confirm ' + actionText}" 
                                              action="{!processApproval}" 
                                              styleClass="btn {!LOWER(action)}"
                                              onclick="this.disabled=true; this.innerHTML='<span class=&quot;loading&quot;></span>Processing...'; return true;"/>
                            
                            <a href="javascript:history.back()" class="btn secondary">Cancel</a>
                        </div>
                    </div>
                </apex:outputPanel>
                
                <!-- Show result -->
                <apex:outputPanel rendered="{!isProcessed}">
                    <div class="header {!statusClass}">
                        <h1>
                            <apex:outputText value="✓ Action Completed Successfully" rendered="{!statusClass == 'success'}"/>
                            <apex:outputText value="✗ Action Failed" rendered="{!statusClass == 'error'}"/>
                        </h1>
                        <p class="subtitle">
                            <apex:outputText value="WFH Request Processed" rendered="{!statusClass == 'success'}"/>
                            <apex:outputText value="Processing Error" rendered="{!statusClass == 'error'}"/>
                        </p>
                    </div>
                    
                    <div class="content">
                        <div class="result-section">
                            <div class="result {!statusClass}">
                                <div class="result-icon">
                                    <apex:outputText value="✅" rendered="{!statusClass == 'success'}"/>
                                    <apex:outputText value="❌" rendered="{!statusClass == 'error'}"/>
                                </div>
                                <h2 class="result-title">{!resultMessage}</h2>
                                <p class="result-message">
                                    <apex:outputText value="The employee has been automatically notified of your decision via email. The attendance record has been updated accordingly." rendered="{!statusClass == 'success'}"/>
                                    <apex:outputText value="Please try again or contact your system administrator if the problem persists." rendered="{!statusClass == 'error'}"/>
                                </p>
                            </div>
                        </div>
                        
                        <apex:outputPanel rendered="{!statusClass == 'success'}">
                            <div class="info-box">
                                <h4>What happens next?</h4>
                                <ul class="info-list">
                                    <li>Employee receives immediate email notification</li>
                                    <li>Attendance record is updated in Salesforce</li>
                                    <li>HR team is notified of the decision</li>
                                    <li>Changes are reflected in payroll systems</li>
                                </ul>
                            </div>
                        </apex:outputPanel>
                    </div>
                </apex:outputPanel>
                
                <!-- Error state -->
                <apex:outputPanel rendered="{!NOT(showForm) && NOT(isProcessed)}">
                    <div class="header">
                        <h1>⚠️ Invalid Request</h1>
                        <p class="subtitle">Unable to Process</p>
                    </div>
                    
                    <div class="content">
                        <div class="result-section">
                            <div class="result info">
                                <div class="result-icon">⚠️</div>
                                <h2 class="result-title">Unable to Process Request</h2>
                                <p class="result-message">
                                    The approval link appears to be invalid, expired, or has already been processed. 
                                    Please check the original email or contact the employee directly.
                                </p>
                            </div>
                        </div>
                        
                        <div class="info-box">
                            <h4>Possible Reasons:</h4>
                            <ul class="info-list">
                                <li>The approval link has expired</li>
                                <li>The request has already been processed</li>
                                <li>Invalid or missing parameters in the URL</li>
                                <li>Employee attendance record not found</li>
                            </ul>
                        </div>
                        
                        <div class="button-section">
                            <a href="javascript:history.back()" class="btn secondary">Go Back</a>
                        </div>
                    </div>
                </apex:outputPanel>
            </apex:form>
            
            <!-- Footer -->
            <div class="footer">
                <p>&copy; 2025 Attendance Management System. All rights reserved.</p>
                <div class="footer-links">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">Contact Support</a>
                </div>
            </div>
        </div>
        
        <!-- JavaScript for enhanced interactions -->
        <script>
            // Auto-focus on comments field
            document.addEventListener('DOMContentLoaded', function() {
                const commentsField = document.getElementById('comments');
                if (commentsField && !window.location.hash) {
                    setTimeout(() => commentsField.focus(), 500);
                }
            });
            
            // Prevent double submission
            let isSubmitting = false;
            function preventDoubleSubmit() {
                if (isSubmitting) return false;
                isSubmitting = true;
                return true;
            }
            
            // Enhanced button interactions
            document.querySelectorAll('.btn').forEach(button => {
                button.addEventListener('click', function(e) {
                    if (this.classList.contains('approve') || this.classList.contains('reject')) {
                        return preventDoubleSubmit();
                    }
                });
            });
            
            // Keyboard shortcuts
            document.addEventListener('keydown', function(e) {
                if (e.ctrlKey || e.metaKey) {
                    if (e.key === 'Enter') {
                        const approveBtn = document.querySelector('.btn.approve');
                        if (approveBtn && !isSubmitting) {
                            approveBtn.click();
                        }
                    }
                }
                
                if (e.key === 'Escape') {
                    history.back();
                }
            });
            
            // Add ripple effect to buttons
            document.querySelectorAll('.btn').forEach(button => {
                button.addEventListener('click', function(e) {
                    const ripple = document.createElement('span');
                    const rect = this.getBoundingClientRect();
                    const size = Math.max(rect.width, rect.height);
                    const x = e.clientX - rect.left - size / 2;
                    const y = e.clientY - rect.top - size / 2;
                    
                    ripple.style.width = ripple.style.height = size + 'px';
                    ripple.style.left = x + 'px';
                    ripple.style.top = y + 'px';
                    ripple.classList.add('ripple');
                    
                    this.appendChild(ripple);
                    
                    setTimeout(() => {
                        ripple.remove();
                    }, 600);
                });
            });
        </script>
        
        <style>
            .ripple {
                position: absolute;
                border-radius: 50%;
                background-color: rgba(255, 255, 255, 0.4);
                transform: scale(0);
                animation: ripple-animation 0.6s linear;
                pointer-events: none;
            }
            
            @keyframes ripple-animation {
                to {
                    transform: scale(4);
                    opacity: 0;
                }
            }
        </style>
    </body>
    </html>
</apex:page>